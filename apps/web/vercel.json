{
  "rewrites": [
    {
      "source": "/event/:slug/game",
      "destination": "/index.html"
    },
    {
      "source": "/event/:slug/game/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/event/:slug/admin",
      "destination": "/index.html"
    },
    {
      "source": "/event/:slug/admin/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/event/:slug/redeem",
      "destination": "/index.html"
    },
    {
      "source": "/event/:slug/redemptions",
      "destination": "/index.html"
    },
    {
      "source": "/event/:slug",
      "destination": "https://neighborly-events-site.vercel.app/event/:slug"
    },
    {
      "source": "/event/:slug/:path*",
      "destination": "https://neighborly-events-site.vercel.app/event/:slug/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/event/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://neighborly-events-site.vercel.app/_next/:path*"
    },
    {
      "source": "/auth/callback",
      "destination": "https://neighborly-events-site.vercel.app/auth/callback"
    },
    {
      "source": "/",
      "destination": "https://neighborly-events-site.vercel.app/"
    }
  ]
}
