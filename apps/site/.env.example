NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Canonical user-facing origin for absolute URLs in SSR metadata
# (Open Graph / Twitter card image URLs, og:url). Set this to apps/web's
# hostname — apps/site sits behind apps/web's Vercel rewrite, so unfurl
# clicks should land on apps/web first per the proxy topology in
# `apps/web/vercel.json`. Local dev typically uses `http://localhost:3000`;
# production reads apps/web's primary alias from the Vercel dashboard.
NEXT_PUBLIC_SITE_ORIGIN=
